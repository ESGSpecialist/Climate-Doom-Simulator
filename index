            <div class="bg-slate-950/60 p-5 rounded-2xl border border-slate-800 space-y-3">
                <div class="inline-flex p-2 bg-red-500/10 rounded-lg text-red-400" id="scenario-icon-container">
                    <i data-lucide="thermometer" id="scenario-icon"></i>
                </div>
                <p id="scenario-text" class="text-base md:text-lg font-medium leading-relaxed text-slate-200">
                    คำถามจำลองสถานการณ์...
                </p>
            </div>

            <!-- Answer Options -->
            <div class="space-y-3" id="options-container">
                <!-- Buttons will be generated dynamically -->
            </div>
        </div>

