                    year: "2595",
                    temp: "+4.0°C",
                    explanation: "เมื่อโลกเดือดชื้นขึ้น ยุงยักษ์สายพันธุ์โบราณที่ฟื้นคืนชีพจากการละลายของธารน้ำแข็งขั้วโลกได้บุกเข้าเขตราตรีเพื่อหาแหล่งอาหาร คุณถูกกัดขณะกำลังเดินตามหาร้านชานมไข่มุกแก้วสุดท้าย สิ้นชีพด้วยไข้ป่าโบราณที่ไม่มีวัคซีนตัวใดรักษาได้ในปัจจุบัน"
                }
            ],
            worker: [
                {
                    cause: "เป็นลมแดดล้มพับคาสะพานลอยกรุงเทพฯ 🚶‍♂️🔥",
                    year: "2580",
                    temp: "+1.5°C",
                    explanation: "คุณต้องเดินทางฝ่าความร้อนสุดขีดเพื่อไปทำงานท่ามกลางฝุ่นละอองสะสมและเกาะความร้อนเมือง (Urban Heat Island Effect) ร่างกายสะสมความร้อนสูงเกินขีดจำกัดขณะเดินขึ้นสะพานลอยพอดิบพอดี สิ้นใจอย่างฮีโร่ผู้สู้ชีวิตแต่โดนสภาวะภูมิอากาศแปรปรวนสู้กลับ!"
                },
                {
                    cause: "จมน้ำป๋อมแป๋มคาสมาร์ทโฮมชั้น 1 🌊🏠",
                    year: "2590",
                    temp: "+3.0°C",
                    explanation: "ระดับน้ำทะเลหนุนสูงถาวรประกอบกับพายุหมุนเขตร้อนที่ทวีความรุนแรงอย่างบ้าคลั่ง ซัดพัดผ่านพังคันกั้นน้ำกรุงเทพฯ จนจมบาดาลถาวร คุณที่พยายามสู้ชีวิตนอนหลับพักผ่อนหลังจากลุยงานหนัก ตื่นขึ้นมาอีกทีก็พบว่าตัวเองลอยอยู่ติดเพดานห้องนอนเรียบร้อยแล้ว"
                }
            ],
            camper: [
                {
                    cause: "ขิตเพราะพายุลูกเห็บยักษ์ซัดเต็นท์ทะลu 🏕️☄️",
                    year: "2588",
                    temp: "+2.5°C",
                    explanation: "ความร้อนจัดสะสมในชั้นบรรยากาศทำให้พยากรณ์อากาศล้มเหลว เกิดพายุฤดูร้อนและพายุลูกเห็บขนาดเท่าลูกมะพร้าวตกลงมาอย่างฉับพลันกลางจุดกางเต็นท์ป่าดิบชื้น เต็นท์พรีเมียมของคุณรับน้ำหนักไม่ไหว ขิตอย่างสงบพร้อมกับเสียงสวดส่งวิญญาณจากเหล่าจักจั่นป่า"
                },
                {
                    cause: "โดนสารพิษและสปอร์เชื้อราโบราณสอยร่วง 🍄☠️",
                    year: "2598",
                    temp: "+4.0°C",
                    explanation: "การที่ระบบนิเวศป่าไม้ดั้งเดิมเหี่ยวเฉาแห้งแล้งและพังทลายอย่างถาวรจากสภาพภูมิอากาศสุดขั้ว ทำให้เชื้อราและเห็ดมีพิษโบราณที่ไม่เคยพบมาก่อนเจริญเติบโตอย่างรวดเร็ว คุณสูดดมสปอร์พิษเข้าไปขณะกำลังเดินทางศึกษาธรรมชาติ ขิตในอ้อมกอดของธรรมชาติป่าไม้เสื่อมโทรม"
                }
            ]
        };

        function selectArchetype(type) {
            archetype = type;
            if (selectedArchBtn) {
                selectedArchBtn.classList.remove('border-red-500', 'bg-red-500/10', 'glow-red');
                selectedArchBtn.classList.add('border-slate-800', 'bg-slate-950/40');
            }
            selectedArchBtn = document.getElementById('arch-' + type);
            selectedArchBtn.classList.remove('border-slate-800', 'bg-slate-950/40');
            selectedArchBtn.classList.add('border-red-500', 'bg-red-500/10', 'glow-red');
        }

        function startGame() {
            nickname = document.getElementById('username').value.trim() || "ผู้รอดชีวิตนิรนาม";
            document.getElementById('screen-intro').classList.add('hidden');
            document.getElementById('screen-quiz').classList.remove('hidden');
            currentStep = 0;
            score = 0;
            showScenario();
        }

        function showScenario() {
            const data = scenarios[currentStep];
            document.getElementById('question-number').innerText = `SCENARIO ${currentStep + 1} / 5`;
            document.getElementById('scenario-title').innerText = data.title;
            document.getElementById('temp-gauge').innerText = data.temp;
            document.getElementById('scenario-text').innerText = data.text;
            
            const iconContainer = document.getElementById('scenario-icon-container');
            iconContainer.innerHTML = `<i data-lucide="${data.icon}" class="w-8 h-8"></i>`;
            
            const optionsContainer = document.getElementById('options-container');
            optionsContainer.innerHTML = '';
            
            data.options.forEach((opt, idx) => {
                const btn = document.createElement('button');
                btn.className = "w-full p-4 bg-slate-950/40 hover:bg-slate-950/80 border border-slate-800 hover:border-red-500/50 rounded-2xl text-left transition-all text-sm font-medium flex items-center justify-between group";
                btn.innerHTML = `
                    <span>${opt.text}</span>
                    <i data-lucide="chevron-right" class="w-4 h-4 text-slate-500 group-hover:text-red-500 transition-colors"></i>
                `;
                btn.onclick = () => selectOption(opt.score);
                optionsContainer.appendChild(btn);
            });
            
            lucide.createIcons();
        }

        function selectOption(optScore) {
            score += optScore;
            currentStep++;
            if (currentStep < scenarios.length) {
                showScenario();
            } else {
                showResult();
            }
        }

        function showResult() {
            document.getElementById('screen-quiz').classList.add('hidden');
            document.getElementById('screen-result').classList.remove('hidden');

            const index = score >= 5 ? 1 : 0;
            const cod = codProfiles[archetype][index];

            const archNames = {
                gamer: "🎮 สายแอร์ฉ่ำสิงหน้าจอ",
                boba: "🧋 สายหวานรักชาไข่มุก",
                worker: "💼 คนเมืองสู้ชีวิตตัวจริง",
                camper: "🏕️ สายแคมป์ลุยธรรมชาติ"
            };

            document.getElementById('cert-cause').innerText = cod.cause;
            document.getElementById('cert-name').innerText = nickname;
            document.getElementById('cert-arch').innerText = archNames[archetype];
            document.getElementById('cert-year').innerText = cod.year;
            document.getElementById('cert-temp').innerText = cod.temp;
            document.getElementById('cert-explanation').innerText = cod.explanation;
            
            const finalRate = Math.min(15 + (score * 8), 85) - (archetype === 'gamer' ? 5 : 0);
            document.getElementById('cert-rate').innerText = finalRate + "%";
            
            const rateEl = document.getElementById('cert-rate');
            if (finalRate < 30) {
                rateEl.className = "text-4xl font-black text-red-600";
            } else if (finalRate < 60) {
                rateEl.className = "text-4xl font-black text-amber-500";
            } else {
                rateEl.className = "text-4xl font-black text-emerald-500";
            }
        }

        function shareResult() {
            const cause = document.getElementById('cert-cause').innerText;
            const year = document.getElementById('cert-year').innerText;
            const temp = document.getElementById('cert-temp').innerText;
            const rate = document.getElementById('cert-rate').innerText;
            const arch = document.getElementById('cert-arch').innerText;

            const textToCopy = `💀 [Climate Doom Simulator] ถ้าโลกเดือด... ผม/ฉันจะขิตท่าไหน?\n\n` +
                               `👤 ผู้วายชนม์: ${nickname}\n` +
                               `🧬 ไลฟ์สไตล์: ${arch}\n` +
                               `🪦 สาเหตุการขิต: ${cause}\n` +
                               `📅 สิ้นชีพปี พ.ศ.: ${year} (ที่อุณหภูมิโลกวิกฤต ${temp})\n` +
                               `🛡️ โอกาสอยู่รอดในอนาคต: ${rate}\n\n` +
                               `ถ้าไม่อยากให้คำพยากรณ์สุดดาร์กนี้เกิดขึ้นจริง! มาร่วมเรียนรู้การคำนวณและลดคาร์บอนฟุตพริ้นท์ตามมาตรฐาน อบก. (TGO) ได้ที่เพจของเราเลยครับ 🌱🌎✨`;

            const tempTextArea = document.createElement("textarea");
            tempTextArea.value = textToCopy;
            document.body.appendChild(tempTextArea);
            tempTextArea.select();
            
            try {
                document.execCommand('copy');
                showToast("คัดลอกผลลัพธ์เพื่อนำไปโพสต์ Facebook เรียบร้อยแล้ว! 🎉");
            } catch (err) {
                showToast("เกิดข้อผิดพลาดในการคัดลอกข้อความ");
            }
            document.body.removeChild(tempTextArea);
        }

        function showToast(message) {
            const toast = document.getElementById('toast');
            document.getElementById('toast-text').innerText = message;
            toast.classList.remove('opacity-0', 'pointer-events-none');
            toast.classList.add('opacity-100');
            
            setTimeout(() => {
                toast.classList.remove('opacity-100');
                toast.classList.add('opacity-0', 'pointer-events-none');
            }, 3000);
        }

        function resetGame() {
            document.getElementById('screen-result').classList.add('hidden');
            document.getElementById('screen-intro').classList.remove('hidden');
            document.getElementById('username').value = '';
            if (selectedArchBtn) {
                selectedArchBtn.classList.remove('border-red-500', 'bg-red-500/10', 'glow-red');
                selectedArchBtn.classList.add('border-slate-800', 'bg-slate-950/40');
                selectedArchBtn = null;
            }
        }

        selectArchetype('gamer');
    </script>
</body>
</html>
