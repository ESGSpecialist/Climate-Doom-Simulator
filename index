                        </button>
                        <button onclick="selectArchetype('camper')" id="arch-camper" class="p-3 bg-slate-950/40 border border-slate-800 rounded-xl hover:border-red-500/50 hover:bg-slate-950/60 text-left transition-all text-xs font-semibold flex items-center gap-2">
