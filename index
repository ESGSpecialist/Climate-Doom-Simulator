        <!-- Lava Top Bar Decoration -->
        <div class="absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r from-red-600 via-orange-500 to-amber-500"></div>

        <!-- 1. Intro Screen -->
        <div id="screen-intro" class="space-y-6 text-center py-6">
            <div class="inline-flex items-center justify-center p-4 bg-red-500/10 rounded-full border border-red-500/30 text-red-500 mb-2 animate-pulse">
