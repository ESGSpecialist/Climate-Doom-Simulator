                    <h3 id="scenario-title" class="text-base font-bold text-slate-300">ระดับอุณหภูมิขยับขึ้น</h3>
                </div>
                <div class="text-right">
                    <span class="text-xs text-slate-400 block font-medium">สภาวะโลกเดือด</span>
                    <span id="temp-gauge" class="text-xl font-black text-orange-500">+1.5°C</span>
                </div>
            </div>

